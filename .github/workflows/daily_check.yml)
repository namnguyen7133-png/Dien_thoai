name: He_Thong_Mat_Than_6AM

on:
  schedule:
    # 22:50 UTC là 5:50 sáng giờ VN
    - cron: '50 22 * * *'
  workflow_dispatch:

jobs:
  run_web_logic:
    runs-on: ubuntu-latest
    steps:
      - name: Kich hoat trang web tu tinh toan
        run: |
          # Dung curl de tai trang web, lam cho Javascript ben trong tu kich hoat
          USER_URL="https://${{ github.repository_owner }}.github.io/${{ github.event.repository.name }}/index.html"
          curl -L $USER_URL
          echo "Da vao trang web: $USER_URL va kich hoat Pushbullet."
