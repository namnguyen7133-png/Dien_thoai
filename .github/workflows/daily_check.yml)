name: He_Thong_Mat_Than_Tong_Hop

on:
  schedule:
    # Chạy lúc 22:50 UTC (tức 5:50 AM giờ Việt Nam) để báo trước 6h
    - cron: '50 22 * * *'
  workflow_dispatch: # Để anh có thể bấm nút "Run workflow" kiểm tra ngay

jobs:
  check_status:
    runs-on: ubuntu-latest
    steps:
      - name: Kich hoat trung tam dieu hanh
        run: |
          # Lệnh này sẽ "mở" trang web của anh để mã JavaScript bên trong tự chạy
          # Lưu ý: Anh phải bật GitHub Pages trong phần Settings thì lệnh này mới hiệu quả
          curl -L https://${{ github.repository_owner }}.github.io/${{ github.event.repository.name }}/index.html
          
      - name: Thong bao kich hoat thanh cong
        run: echo "He thong da quet trang web luc $(date)"
